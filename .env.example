# ---- RunPod (Texas / US-TX-3) ----
RUNPOD_API_KEY=
RUNPOD_POD_ID=
RUNPOD_POD_HOST=            # e.g. xxxxx-8888.proxy.runpod.net
RUNPOD_DATACENTER=US-TX-3
# ---- TRELLIS (image -> 3D, running on the pod) ----
TRELLIS_ENDPOINT=           # http://$RUNPOD_POD_HOST/generate
TRELLIS_SS_STEPS=12
TRELLIS_SLAT_STEPS=12
TRELLIS_MESH_SIMPLIFY=0.95
TRELLIS_TEXTURE_SIZE=1024
# ---- FLUX (reference image gen, same pod) ----
FLUX_ENDPOINT=
FLUX_STEPS=28
FLUX_GUIDANCE=3.5
# ---- Grok / xAI (BUILD TIME ONLY — never bundled) ----
XAI_API_KEY=
XAI_MODEL=grok-4
XAI_BASE_URL=https://api.x.ai/v1
# ---- Build ----
VITE_BASE_PATH=/games/pinball
VITE_ENABLE_DEBUG_OVERLAY=false
